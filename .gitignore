# Git ignore rules

# Environment
.env
.env.local
.env.*.local
.env.production

# Claude local settings
.claude/settings.local.json
.claude/CLAUDE.local.md

# Yii Framework
/framework/*
!/framework/.gitkeep
protected/runtime/
/assets/

# Dependencies
node_modules/

# Build output
dist/
build/
out/

# Logs
logs/
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# Test coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/

# Uploads
uploads/
protected/config/database.php
protected/config/params.php
protected/config/main.php
